<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/card_dark"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Share your day"
        android:textColor="@color/text_white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:boxStrokeColor="@color/accent_cyan"
        app:hintTextColor="@color/accent_cyan">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/postContentEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="top"
            android:hint="What's on your mind?"
            android:minLines="3"
            android:textColor="@color/text_white" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/postScorePreview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Your Productivity Score: --"
        android:textColor="@color/accent_cyan"
        android:textSize="14sp" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkSteps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Include Step Count"
        android:textColor="@color/text_secondary"
        app:buttonTint="@color/accent_cyan" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/checkHR"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Include Heart Rate"
        android:textColor="@color/text_secondary"
        app:buttonTint="@color/accent_cyan" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Visibility"
        android:textColor="@color/text_white"
        android:textSize="14sp" />

    <RadioGroup
        android:id="@+id/visibilityGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/radioPublic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Public"
            android:textColor="@color/text_secondary"
            app:buttonTint="@color/accent_cyan" />

        <RadioButton
            android:id="@+id/radioFriends"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Friends Only"
            android:textColor="@color/text_secondary"
            app:buttonTint="@color/accent_cyan" />
    </RadioGroup>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPost"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Post"
        app:backgroundTint="@color/accent_cyan"
        app:cornerRadius="8dp" />

</LinearLayout>