<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- App Title -->
            <TextView
                android:id="@+id/appTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MindShield"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:fontFamily="sans-serif-medium"/>

            <!-- Greeting -->
            <TextView
                android:id="@+id/greetingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/appTitle"
                android:layout_marginTop="4dp"
                android:text="Good Evening"
                android:textSize="14sp"
                android:textColor="#B3FFFFFF"/>

            <!-- Avatar -->
            <ImageView
                android:id="@+id/profileAvatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_glass_card"
                android:padding="8dp"
                android:src="@drawable/ic_profile_placeholder"/>
        </RelativeLayout>

        <!-- HERO SCORE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_ripple"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Wellness Score"
                android:textSize="14sp"
                android:textColor="#B3FFFFFF"/>

            <TextView
                android:id="@+id/scoreValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="82"
                android:textSize="50sp"
                android:textStyle="bold"
                android:textColor="@color/accent_green"/>

            <TextView
                android:id="@+id/scoreStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Excellent"
                android:textSize="18sp"
                android:textColor="@color/text_white"/>

            <TextView
                android:id="@+id/scoreSubText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="You're doing better than yesterday 🚀"
                android:textSize="13sp"
                android:textColor="#B3FFFFFF"/>
        </LinearLayout>

        <!-- QUICK METRICS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingStart="16dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_glass_card"
                    android:padding="12dp"
                    android:text="Sleep\n7.2h"
                    android:textColor="@color/text_white"
                    android:textSize="14sp"/>

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_glass_card"
                    android:padding="12dp"
                    android:text="Screen\n5h"
                    android:textColor="@color/text_white"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/heartValue"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_glass_card"
                    android:padding="12dp"
                    android:text="Heart\n-- bpm"
                    android:textColor="@color/text_white"
                    android:textSize="14sp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- AI INSIGHT -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="164dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/bg_glass_ripple"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/stepsValue"
                android:layout_width="333dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:background="@drawable/bg_glass_card"
                android:padding="12dp"
                android:text="Steps\n--"
                android:textColor="@color/text_white"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧠 AI Insight"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/aiInsight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Analyzing your behavior..."
                android:textColor="#B3FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/connectFitButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect Google Fit"
            android:textColor="#00E5FF"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/usageValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textSize="18sp"/>

        <!-- CHART -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_glass_ripple"
            android:padding="16dp">

            <com.github.mikephil.charting.charts.PieChart
                android:id="@+id/pieChart"
                android:layout_width="match_parent"
                android:layout_height="220dp"/>
        </LinearLayout>

        <!-- TOP APPS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_ripple"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Top Apps Used"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"/>

            <LinearLayout
                android:id="@+id/topAppsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>
